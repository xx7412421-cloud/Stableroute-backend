{
  "name": "stableroute-backend",
  "version": "0.1.0",
  "description": "StableRoute API gateway, routing engine, and pricing service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
